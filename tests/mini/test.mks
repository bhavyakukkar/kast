const add = (a :: Int32, b :: Int32) -> Int32 => (
    @native "\(a) + \(b)"
);

const sub = (a :: Int32, b :: Int32) -> Int32 => (
    @native "\(a) - \(b)"
);

const less = (a :: Int32, b :: Int32) -> Bool => (
    @native "\(a) < \(b)"
);

const fib = (n :: Int32) -> Int32 => (
    if less(n, @native "2") then (
        @native "1"
    ) else (
        add(fib(sub(n, @native "1")), fib(sub(n, @native "2")))
    )
);

const OptionTag = enum {
    | :Some
    | :None
};

const OptionData = union {
    .Some :: Int32,
    .None :: (),
};

const print = (s :: String) -> () => (
    @native "console.log(\(s))";
);

const int32_to_string = (x :: Int32) -> String => (
    @native "\(x).toString()"
);

const Foo = struct {
    .f :: (Int32) -> (),
    .g :: (Int32) -> (),
};

const main = () -> () => (
    # print(int32_to_string(fib(@native "10")));
    let foo :: Foo = uninitialized;
    foo.f = (depth :: Int32) -> () => (
        print(int32_to_string(depth));
        if less(depth, @native "10") then (
            foo.g(add(depth, @native "1"));
        );
    );
    foo.g = (depth :: Int32) -> () => foo.f(depth);
    foo.g(@native "0");
    print("Hello, world!");
);
